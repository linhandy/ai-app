# Zenmux — for LLM text generation only
ZENMUX_API_KEY=your_zenmux_key_here
ZENMUX_BASE_URL=https://zenmux.ai/api/v1

# OpenAI — for TTS and Whisper (Zenmux does not support audio endpoints)
OPENAI_API_KEY=your_openai_key_here

# Optional: path to ffmpeg binary if not in PATH
# FFMPEG_PATH=/usr/local/bin/ffmpeg
